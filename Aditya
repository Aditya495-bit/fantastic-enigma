<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My College Website</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f4f4f4;
}

header{
    background:#003366;
    color:white;
    text-align:center;
    padding:20px;
}

nav{
    background:#0055aa;
    padding:10px;
    text-align:center;
}

nav a{
    color:white;
    text-decoration:none;
    margin:15px;
    font-weight:bold;
}

section{
    padding:40px;
    text-align:center;
}

.home{
    background:#e3f2fd;
}

.about{
    background:white;
}

.services{
    background:#f9f9f9;
}

.contact{
    background:white;
}

.card{
    display:inline-block;
    width:220px;
    margin:10px;
    padding:20px;
    background:white;
    border-radius:10px;
    box-shadow:0 0 10px gray;
}

button{
    background:#0055aa;
    color:white;
    border:none;
    padding:10px 20px;
    border-radius:5px;
    cursor:pointer;
}

footer{
    background:#003366;
    color:white;
    text-align:center;
    padding:15px;
}
</style>
</head>

<body>

<header>
    <h1>ABC College</h1>
    <p>Welcome to Our College Website</p>
</header>

<nav>
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#services">Courses</a>
    <a href="#contact">Contact</a>
</nav>

<section class="home" id="home">
    <h2>Home</h2>
    <p>Welcome to ABC College. Build your future with us.</p>
    <br>
    <button onclick="showMsg()">Apply Now</button>
</section>

<section class="about" id="about">
    <h2>About Us</h2>
    <p>ABC College provides quality education and modern facilities for students.</p>
</section>

<section class="services" id="services">
    <h2>Our Courses</h2>
    <div class="card">
        <h3>BCA</h3>
        <p>Computer Applications</p>
    </div>

    <div class="card">
        <h3>BBA</h3>
        <p>Business Administration</p>
    </div>

    <div class="card">
        <h3>B.Sc</h3>
        <p>Science Course</p>
    </div>
</section>

<section class="contact" id="contact">
    <h2>Contact Us</h2>
    <p>Email: info@college.com</p>
    <p>Phone: +91 9876543210</p>
</section>

<footer>
    <p>© 2026 ABC College. All Rights Reserved.</p>
</footer>

<script>
function showMsg(){
    alert("Thank You For Visiting Our College Website!");
}
</script>

</body>
</html>
